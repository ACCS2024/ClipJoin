<Window x:Class="ClipJoin.SubdirConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="子目录模式确认"
        Width="520"
        MinHeight="200"
        MaxHeight="560"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F2F5"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header info -->
            <RowDefinition Height="Auto"/>
            <!-- Scrollable group list -->
            <RowDefinition Height="Auto" MaxHeight="340"/>
            <!-- Footer description -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1" Padding="20,16">
            <StackPanel Orientation="Horizontal">
                <Border Width="36" Height="36" Background="#E8F4FF" CornerRadius="18" Margin="0,0,12,0">
                    <TextBlock Text="ℹ" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#1677FF"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" FontSize="15" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                    <TextBlock x:Name="SubtitleText" FontSize="12" Foreground="#8C8C8C" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Scrollable group list -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      MaxHeight="340"
                      Margin="20,12,20,0"
                      Focusable="False">
            <ItemsControl x:Name="GroupList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" BorderBrush="#F0F0F0" BorderThickness="1"
                                CornerRadius="6" Padding="10,7" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="📁" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13"
                                           Foreground="#333" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Name}"/>
                                <Border Grid.Column="2" Background="#F0F7FF" CornerRadius="4"
                                        Padding="8,3" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding CountLabel}" FontSize="12"
                                               Foreground="#1677FF" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer description -->
        <Border Grid.Row="2" Margin="20,12,20,0" Background="#FFFBE6" BorderBrush="#FFE58F"
                BorderThickness="1" CornerRadius="6" Padding="12,8">
            <TextBlock FontSize="12" Foreground="#7C5500" TextWrapping="Wrap"
                       Text="每个文件夹中的视频将被分别合并为独立 MP4 文件，所有输出文件放在同一输出目录下（不创建子文件夹）。"/>
        </Border>

        <!-- Buttons -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E8E8E8" BorderThickness="0,1,0,0"
                Padding="20,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelBtn" Content="取消" Width="90" Height="34" FontSize="13"
                        Background="White" Foreground="#555" BorderBrush="#D9D9D9" BorderThickness="1"
                        Cursor="Hand" Margin="0,0,10,0" Click="CancelBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F5F5F5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="ConfirmBtn" Content="确认合并" Width="100" Height="34" FontSize="13"
                        Background="#1677FF" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="ConfirmBtn_Click" IsDefault="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#4096FF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
