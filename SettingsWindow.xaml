<Window x:Class="ClipJoin.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置 - ClipJoin"
        Height="600" Width="540"
        MinHeight="460" MinWidth="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F0F2F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 固定顶栏 ──────────────────────────────────── -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E8E8E8"
                BorderThickness="0,0,0,1" Padding="24,18,24,16">
            <TextBlock Text="设置" FontSize="20" FontWeight="Bold" Foreground="#1A1A1A"/>
        </Border>

        <!-- ── 可滚动内容区 ──────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Focusable="False">
            <StackPanel Margin="24,20,24,20">

                <!-- 分组标签：AI 智能排序 -->
                <TextBlock Text="AI 智能排序" FontSize="11" FontWeight="SemiBold"
                           Foreground="#8C8C8C" Margin="2,0,0,8"/>

                <!-- AI 设置卡片 -->
                <Border Background="White" BorderBrush="#E8E8E8" BorderThickness="1"
                        CornerRadius="8" Padding="16,14" Margin="0,0,0,20">
                    <StackPanel>

                        <!-- API 端点 -->
                        <TextBlock Text="API 端点" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#333" Margin="0,0,0,6"/>
                        <TextBox x:Name="EndpointTextBox" FontSize="13" Padding="8,7"
                                 BorderBrush="#D9D9D9" BorderThickness="1"
                                 VerticalContentAlignment="Center"/>
                        <TextBlock Text="示例：https://openkey.cloud/v1/chat/completions"
                                   FontSize="11" Foreground="#8C8C8C" Margin="0,3,0,14"/>

                        <Border BorderBrush="#F0F0F0" BorderThickness="0,1,0,0" Margin="0,0,0,14"/>

                        <!-- API Key -->
                        <TextBlock Text="API Key" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#333" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="ApiKeyPasswordBox" FontSize="13" Padding="8,7"
                                         BorderBrush="#D9D9D9" BorderThickness="1"
                                         VerticalContentAlignment="Center"/>
                            <TextBox x:Name="ApiKeyTextBox" FontSize="13" Padding="8,7"
                                     BorderBrush="#D9D9D9" BorderThickness="1"
                                     VerticalContentAlignment="Center" Visibility="Collapsed"/>
                            <Button x:Name="ToggleKeyBtn" Grid.Column="1" Content="👁"
                                    FontSize="14" Padding="8,5" Margin="6,0,0,0"
                                    Background="White" BorderBrush="#D9D9D9" BorderThickness="1"
                                    Cursor="Hand" Click="ToggleKeyVisibility_Click"
                                    ToolTip="显示/隐藏密钥"/>
                        </Grid>
                        <TextBlock Text="密钥仅保存在本地，不会上传到任何服务器"
                                   FontSize="11" Foreground="#8C8C8C" Margin="0,3,0,14"/>

                        <Border BorderBrush="#F0F0F0" BorderThickness="0,1,0,0" Margin="0,0,0,14"/>

                        <!-- 模型名称 -->
                        <TextBlock Text="模型名称" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#333" Margin="0,0,0,6"/>
                        <TextBox x:Name="ModelTextBox" FontSize="13" Padding="8,7"
                                 BorderBrush="#D9D9D9" BorderThickness="1"
                                 VerticalContentAlignment="Center"/>
                        <TextBlock Text="默认：deepseek-v3（推荐，中文排序效果最佳）"
                                   FontSize="11" Foreground="#8C8C8C" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 分组标签：输出文件处理 -->
                <TextBlock Text="输出文件处理" FontSize="11" FontWeight="SemiBold"
                           Foreground="#8C8C8C" Margin="2,0,0,8"/>

                <!-- 冲突处理卡片 -->
                <Border Background="White" BorderBrush="#E8E8E8" BorderThickness="1"
                        CornerRadius="8" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="文件冲突解决方式" FontSize="13" FontWeight="SemiBold" Foreground="#333"/>
                        <TextBlock Text="当目标路径已存在同名输出文件时，按以下方式处理："
                                   FontSize="12" Foreground="#8C8C8C" Margin="0,3,0,14" TextWrapping="Wrap"/>

                        <!-- 每次询问 -->
                        <RadioButton x:Name="ConflictAskRadio" GroupName="Conflict"
                                     Margin="0,0,0,12" Cursor="Hand" VerticalContentAlignment="Top">
                            <StackPanel Margin="6,1,0,0">
                                <TextBlock Text="每次询问（推荐）" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                <TextBlock Text="在每次任务开始前弹出对话框，让您选择处理方式"
                                           FontSize="11" Foreground="#8C8C8C" Margin="0,2,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <!-- 跳过 -->
                        <RadioButton x:Name="ConflictSkipRadio" GroupName="Conflict"
                                     Margin="0,0,0,12" Cursor="Hand" VerticalContentAlignment="Top">
                            <StackPanel Margin="6,1,0,0">
                                <TextBlock Text="跳过" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                <TextBlock Text="保留已有文件，直接跳过重复任务"
                                           FontSize="11" Foreground="#8C8C8C" Margin="0,2,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <!-- 覆盖 -->
                        <RadioButton x:Name="ConflictOverwriteRadio" GroupName="Conflict"
                                     Margin="0,0,0,12" Cursor="Hand" VerticalContentAlignment="Top">
                            <StackPanel Margin="6,1,0,0">
                                <TextBlock Text="覆盖" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                <TextBlock Text="直接覆盖已有文件（不可恢复，请谨慎使用）"
                                           FontSize="11" Foreground="#D46B08" Margin="0,2,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <!-- 自动重命名 -->
                        <RadioButton x:Name="ConflictRenameRadio" GroupName="Conflict"
                                     Cursor="Hand" VerticalContentAlignment="Top">
                            <StackPanel Margin="6,1,0,0">
                                <TextBlock Text="自动重命名" FontSize="13" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                <TextBlock Text="保留已有文件，新文件自动追加 _2、_3… 序号"
                                           FontSize="11" Foreground="#8C8C8C" Margin="0,2,0,0"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ── 固定底栏 ──────────────────────────────────── -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E8E8E8"
                BorderThickness="0,1,0,0" Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText" FontSize="12" Foreground="#52C41A"
                           VerticalAlignment="Center" Visibility="Collapsed" TextWrapping="Wrap"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="TestBtn" Content="测试连接"
                            Padding="16,8" FontSize="13" Margin="0,0,8,0"
                            Background="White" Foreground="#333"
                            BorderBrush="#D9D9D9" BorderThickness="1"
                            Cursor="Hand" Click="TestConnection_Click"/>

                    <Button x:Name="SaveBtn" Content="保 存"
                            Padding="20,8" FontSize="13"
                            Background="#1677FF" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="Save_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#4096FF"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#69B1FF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="取 消" Padding="16,8" FontSize="13" Margin="8,0,0,0"
                            Background="White" Foreground="#333"
                            BorderBrush="#D9D9D9" BorderThickness="1"
                            Cursor="Hand" Click="Cancel_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
