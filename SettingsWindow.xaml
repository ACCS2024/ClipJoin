<Window x:Class="ClipJoin.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 设置 - ClipJoin"
        Height="480" Width="520"
        MinHeight="360" MinWidth="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F0F2F5">

    <!-- Three-row layout: pinned header / scrollable content / pinned footer -->
    <Grid>
        <Grid.RowDefinitions>
            <!-- Pinned header -->
            <RowDefinition Height="Auto"/>
            <!-- Scrollable body (* — fills remaining space) -->
            <RowDefinition Height="*"/>
            <!-- Pinned footer: status + buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────── -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E8E8E8"
                BorderThickness="0,0,0,1" Padding="24,16">
            <StackPanel>
                <TextBlock Text="⚙ AI 排序设置" FontSize="20" FontWeight="Bold" Foreground="#1A1A1A"/>
                <TextBlock Text="配置 AI 接口用于智能排序视频文件（支持 OpenAI 兼容接口）"
                           FontSize="12" Foreground="#8C8C8C" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- ── Scrollable body ────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Focusable="False">
            <StackPanel Margin="24,16,24,16">

                <!-- Settings Card -->
                <Border Background="White" BorderBrush="#E8E8E8" BorderThickness="1"
                        CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <!-- API Endpoint -->
                        <TextBlock Text="API 端点" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <TextBox x:Name="EndpointTextBox" FontSize="13" Padding="8,7"
                                 BorderBrush="#D9D9D9" BorderThickness="1"
                                 VerticalContentAlignment="Center"/>
                        <TextBlock Text="示例: https://openkey.cloud/v1/chat/completions"
                                   FontSize="11" Foreground="#8C8C8C" Margin="0,2,0,12"/>

                        <!-- API Key -->
                        <TextBlock Text="API Key" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="ApiKeyPasswordBox" FontSize="13" Padding="8,7"
                                         BorderBrush="#D9D9D9" BorderThickness="1"
                                         VerticalContentAlignment="Center"/>
                            <TextBox x:Name="ApiKeyTextBox" FontSize="13" Padding="8,7"
                                     BorderBrush="#D9D9D9" BorderThickness="1"
                                     VerticalContentAlignment="Center" Visibility="Collapsed"/>
                            <Button x:Name="ToggleKeyBtn" Grid.Column="1" Content="👁"
                                    FontSize="14" Padding="8,5" Margin="6,0,0,0"
                                    Background="White" BorderBrush="#D9D9D9" BorderThickness="1"
                                    Cursor="Hand" Click="ToggleKeyVisibility_Click"
                                    ToolTip="显示/隐藏密钥"/>
                        </Grid>
                        <TextBlock Text="密钥仅保存在本地，不会上传到任何服务器"
                                   FontSize="11" Foreground="#8C8C8C" Margin="0,2,0,12"/>

                        <!-- Model -->
                        <TextBlock Text="模型名称" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <TextBox x:Name="ModelTextBox" FontSize="13" Padding="8,7"
                                 BorderBrush="#D9D9D9" BorderThickness="1"
                                 VerticalContentAlignment="Center"/>
                        <TextBlock Text="默认: deepseek-v3（推荐用于视频文件智能排序）"
                                   FontSize="11" Foreground="#8C8C8C" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Conflict resolution preference -->
                <Border Background="White" BorderBrush="#E8E8E8" BorderThickness="1"
                        CornerRadius="8" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="输出文件冲突处理" FontSize="13" FontWeight="SemiBold" Foreground="#333"/>
                            <TextBlock x:Name="ConflictPrefText" FontSize="12" Foreground="#8C8C8C" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="重置为「每次询问」"
                                FontSize="12" Padding="10,5"
                                Background="White" Foreground="#1677FF" BorderBrush="#1677FF" BorderThickness="1"
                                Cursor="Hand" Click="ResetConflict_Click" VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E6F4FF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Pinned footer: status + buttons ───────────── -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E8E8E8"
                BorderThickness="0,1,0,0" Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" FontSize="12" Foreground="#52C41A"
                           VerticalAlignment="Center" Visibility="Collapsed" TextWrapping="Wrap"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="测试连接" Padding="16,8" FontSize="13" Margin="0,0,8,0"
                            Background="White" Foreground="#333" BorderBrush="#D9D9D9" BorderThickness="1"
                            Cursor="Hand" Click="TestConnection_Click" x:Name="TestBtn"/>
                    <Button Content="保 存" Padding="20,8" FontSize="13"
                            Background="#1677FF" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="Save_Click" x:Name="SaveBtn">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#4096FF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="取 消" Padding="16,8" FontSize="13" Margin="8,0,0,0"
                            Background="White" Foreground="#333" BorderBrush="#D9D9D9" BorderThickness="1"
                            Cursor="Hand" Click="Cancel_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
