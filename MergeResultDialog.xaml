<Window x:Class="ClipJoin.MergeResultDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="合并完成"
        Width="500"
        MinHeight="180"
        MaxHeight="580"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F2F5"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Stats bar -->
            <RowDefinition Height="Auto"/>
            <!-- Failed list (conditional) -->
            <RowDefinition Height="Auto" MaxHeight="260"/>
            <!-- Buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1" Padding="20,16">
            <StackPanel Orientation="Horizontal">
                <Border x:Name="IconBorder" Width="38" Height="38" CornerRadius="19" Margin="0,0,12,0">
                    <TextBlock x:Name="IconText" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" FontSize="15" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                    <TextBlock x:Name="SubtitleText" FontSize="12" Foreground="#8C8C8C" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Stats bar -->
        <Border Grid.Row="1" Margin="20,12,20,0" Background="White" BorderBrush="#E8E8E8"
                BorderThickness="1" CornerRadius="8" Padding="0">
            <Grid>
                <!-- Three equal cells -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="0,10,0,10">
                    <TextBlock x:Name="SuccessCount" FontSize="22" FontWeight="Bold"
                               Foreground="#52C41A" HorizontalAlignment="Center"/>
                    <TextBlock Text="成功" FontSize="11" Foreground="#8C8C8C" HorizontalAlignment="Center"/>
                </StackPanel>

                <Rectangle Grid.Column="1" Fill="#E8E8E8"/>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center" Margin="0,10,0,10">
                    <TextBlock x:Name="SkipCount" FontSize="22" FontWeight="Bold"
                               Foreground="#8C8C8C" HorizontalAlignment="Center"/>
                    <TextBlock Text="跳过" FontSize="11" Foreground="#8C8C8C" HorizontalAlignment="Center"/>
                </StackPanel>

                <Rectangle Grid.Column="3" Fill="#E8E8E8"/>

                <StackPanel Grid.Column="4" HorizontalAlignment="Center" Margin="0,10,0,10">
                    <TextBlock x:Name="FailCount" FontSize="22" FontWeight="Bold"
                               Foreground="#FF4D4F" HorizontalAlignment="Center"/>
                    <TextBlock Text="失败" FontSize="11" Foreground="#8C8C8C" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Failed group list (only visible when failures exist) -->
        <Border x:Name="FailedSection" Grid.Row="2" Margin="20,10,20,0"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="失败任务详情：" FontSize="12" FontWeight="SemiBold"
                           Foreground="#CC0000" Margin="0,0,0,6"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="220" Focusable="False">
                    <ItemsControl x:Name="FailedList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" BorderBrush="#FFCCC7" BorderThickness="1"
                                        CornerRadius="5" Padding="10,7" Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="❌" FontSize="12" VerticalAlignment="Top" Margin="0,1,8,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding GroupName}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#333" TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding GroupName}"/>
                                            <TextBlock Text="{Binding ErrorMessage}" FontSize="11"
                                                       Foreground="#8C0000" TextWrapping="Wrap"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E8E8E8" BorderThickness="0,1,0,0"
                Padding="20,12" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="OpenFolderBtn" Content="📂 打开输出目录" Height="32" FontSize="13"
                        Padding="14,0"
                        Background="White" Foreground="#1677FF" BorderBrush="#1677FF" BorderThickness="1"
                        Cursor="Hand" Margin="0,0,10,0" Click="OpenFolderBtn_Click"
                        Visibility="Collapsed">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E6F4FF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="CloseBtn" Content="关 闭" Width="82" Height="32" FontSize="13"
                        Background="#1677FF" Foreground="White" BorderThickness="0"
                        Cursor="Hand" IsDefault="True" Click="CloseBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#4096FF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
