<Window x:Class="ClipJoin.ManualSortWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="手动排序 - ClipJoin"
        Height="600" Width="580"
        MinHeight="450" MinWidth="450"
        WindowStartupLocation="CenterOwner"
        Background="#F0F2F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="📋 手动排序" FontSize="20" FontWeight="Bold" Foreground="#1A1A1A"/>
            <TextBlock Text="拖拽文件或使用按钮调整播放顺序" FontSize="12" Foreground="#8C8C8C" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Group selector (for SubDirectory mode) -->
        <Grid Grid.Row="1" x:Name="GroupSelectorPanel" Visibility="Collapsed" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="当前文件夹:" FontSize="13" Foreground="#333" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="GroupComboBox" Grid.Column="1" FontSize="13" Padding="6,5"
                      SelectionChanged="GroupComboBox_SelectionChanged"/>
        </Grid>

        <!-- File list -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E8E8E8" BorderThickness="1"
                CornerRadius="8" Padding="4">
            <ListBox x:Name="FileListBox" FontSize="13" FontFamily="Consolas, Microsoft YaHei"
                     BorderThickness="0" Background="Transparent"
                     SelectionMode="Extended"
                     AllowDrop="True"
                     PreviewMouseLeftButtonDown="FileListBox_PreviewMouseLeftButtonDown"
                     PreviewMouseMove="FileListBox_PreviewMouseMove"
                     Drop="FileListBox_Drop"
                     DragOver="FileListBox_DragOver">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Index}" FontSize="12" Foreground="#8C8C8C"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="{Binding FileName}" FontSize="13"
                                       Foreground="#333" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding FileName}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Control buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10">
            <Button Content="⬆ 上移" Padding="14,7" FontSize="13" Margin="0,0,6,0"
                    Background="White" Foreground="#333" BorderBrush="#D9D9D9" BorderThickness="1"
                    Cursor="Hand" Click="MoveUp_Click" ToolTip="Ctrl+Up"/>
            <Button Content="⬇ 下移" Padding="14,7" FontSize="13" Margin="0,0,6,0"
                    Background="White" Foreground="#333" BorderBrush="#D9D9D9" BorderThickness="1"
                    Cursor="Hand" Click="MoveDown_Click" ToolTip="Ctrl+Down"/>
            <Button Content="⏫ 置顶" Padding="14,7" FontSize="13" Margin="0,0,6,0"
                    Background="White" Foreground="#333" BorderBrush="#D9D9D9" BorderThickness="1"
                    Cursor="Hand" Click="MoveToTop_Click"/>
            <Button Content="⏬ 置底" Padding="14,7" FontSize="13" Margin="0,0,6,0"
                    Background="White" Foreground="#333" BorderBrush="#D9D9D9" BorderThickness="1"
                    Cursor="Hand" Click="MoveToBottom_Click"/>
            <Button Content="🔄 重置" Padding="14,7" FontSize="13"
                    Background="White" Foreground="#333" BorderBrush="#D9D9D9" BorderThickness="1"
                    Cursor="Hand" Click="Reset_Click" ToolTip="恢复自然排序"/>
        </StackPanel>

        <!-- Confirm -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确认排序" Padding="20,8" FontSize="14"
                    Background="#1677FF" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="Confirm_Click"/>
            <Button Content="取 消" Padding="16,8" FontSize="13" Margin="8,0,0,0"
                    Background="White" Foreground="#333" BorderBrush="#D9D9D9" BorderThickness="1"
                    Cursor="Hand" Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
