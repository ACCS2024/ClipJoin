<Window x:Class="ClipJoin.ConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输出文件冲突"
        Width="500"
        MinHeight="200"
        MaxHeight="560"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F2F5"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Conflict file list (scrollable) -->
            <RowDefinition Height="Auto" MaxHeight="220"/>
            <!-- Resolution options -->
            <RowDefinition Height="Auto"/>
            <!-- Remember checkbox -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1" Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <Border Width="34" Height="34" Background="#FFF7E6" CornerRadius="17" Margin="0,0,12,0">
                    <TextBlock Text="⚠" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FA8C16"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" FontSize="14" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                    <TextBlock x:Name="SubtitleText" FontSize="12" Foreground="#8C8C8C" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Conflict file list -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="20,12,20,0"
                      Focusable="False">
            <ItemsControl x:Name="ConflictList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" BorderBrush="#FFE7BA" BorderThickness="1"
                                CornerRadius="5" Padding="10,6" Margin="0,0,0,3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="📄" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding GroupName}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#333" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding GroupName}"/>
                                    <TextBlock Text="{Binding OutputFile}" FontSize="11" Foreground="#8C8C8C"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding OutputFile}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Resolution options -->
        <Border Grid.Row="2" Margin="20,12,20,0" Background="White" BorderBrush="#E8E8E8"
                BorderThickness="1" CornerRadius="8" Padding="14,10">
            <StackPanel>
                <TextBlock Text="请选择处理方式：" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>

                <RadioButton x:Name="RadioSkip" GroupName="Resolution" IsChecked="True"
                             Margin="0,0,0,6" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏭  跳过已存在的文件" FontSize="13" Foreground="#333" VerticalAlignment="Center"/>
                        <Border Background="#F6FFED" BorderBrush="#B7EB8F" BorderThickness="1"
                                CornerRadius="3" Padding="6,1" Margin="8,0,0,0">
                            <TextBlock Text="推荐" FontSize="11" Foreground="#389E0D"/>
                        </Border>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="RadioOverwrite" GroupName="Resolution"
                             Margin="0,0,0,6" Cursor="Hand">
                    <TextBlock Text="♻  覆盖已存在的文件" FontSize="13" Foreground="#333" VerticalAlignment="Center"/>
                </RadioButton>

                <RadioButton x:Name="RadioRename" GroupName="Resolution" Cursor="Hand">
                    <TextBlock Text="📄  自动重命名输出文件（例如：剧名_2.mp4）" FontSize="13" Foreground="#333" VerticalAlignment="Center"/>
                </RadioButton>
            </StackPanel>
        </Border>

        <!-- Remember choice -->
        <Border Grid.Row="3" Margin="20,8,20,0">
            <CheckBox x:Name="RememberCheck" FontSize="12" Foreground="#595959" Cursor="Hand"
                      Content="记住我的选择（可在 ⚙ 设置中重置）"/>
        </Border>

        <!-- Buttons -->
        <Border Grid.Row="4" Background="White" BorderBrush="#E8E8E8" BorderThickness="0,1,0,0"
                Padding="20,12" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelBtn" Content="取消" Width="80" Height="32" FontSize="13"
                        Background="White" Foreground="#555" BorderBrush="#D9D9D9" BorderThickness="1"
                        Cursor="Hand" Margin="0,0,10,0" Click="CancelBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F5F5F5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="ConfirmBtn" Content="继续合并" Width="96" Height="32" FontSize="13"
                        Background="#1677FF" Foreground="White" BorderThickness="0"
                        Cursor="Hand" IsDefault="True" Click="ConfirmBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#4096FF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
